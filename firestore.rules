rules_version = '2';
service cloud.firestore {

  function canEditCodespace() {
    return request.auth.token.email in ['abhishekbasu188@gmail.com']
           || (exists(/databases/$(database)/documents/codespaceAccess/$(request.auth.uid))
               && get(/databases/$(database)/documents/codespaceAccess/$(request.auth.uid)).data.role == 'editor');
  }

  match /databases/{database}/documents {

    // ── PDFs (public read, admin write; non-admin may bump likeCount only) ──
    match /pdfs/{docId} {
      allow read: if true;
      allow create, delete: if request.auth != null
                   && request.auth.token.email in ['abhishekbasu188@gmail.com'];
      allow update: if request.auth != null
                   && (
                     request.auth.token.email in ['abhishekbasu188@gmail.com']
                     || request.resource.data.diff(resource.data).affectedKeys()
                          .hasOnly(['likeCount'])
                   );
    }

    // ── Views (logged-in users write their own) ──
    match /views/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null
                    && resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    // ── Downloads (logged-in users write their own) ──
    match /downloads/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    // ── Chat messages ──
    match /chats/{room}/messages/{msgId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid
                    && (
                      // Text message
                      (request.resource.data.keys().hasAny(['text'])
                        && request.resource.data.text.size() <= 1000)
                      ||
                      // Media message
                      (request.resource.data.keys().hasAny(['mediaUrl'])
                        && request.resource.data.mediaType in ['image', 'video'])
                    );
      allow delete: if request.auth != null
                    && (resource.data.uid == request.auth.uid
                    || request.auth.token.email in ['abhishekbasu188@gmail.com']);
      allow update: if false;
    }

    // ── Presence ──
    match /presence/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == uid;
    }

    // ── Typing indicators ──
    match /typing/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── Friend Requests ──
    match /friendRequests/{docId} {
      allow read: if request.auth != null
                  && (resource.data.from == request.auth.uid
                  || resource.data.to == request.auth.uid
                  || request.auth.token.email in ['abhishekbasu188@gmail.com']);
      allow create: if request.auth != null
                    && request.resource.data.from == request.auth.uid;
      allow update: if request.auth != null
                    && resource.data.to == request.auth.uid;
      allow delete: if request.auth != null
                    && (resource.data.from == request.auth.uid
                    || resource.data.to == request.auth.uid);
    }

    // ── Friendships ──
    match /friendships/{docId} {
      allow read: if request.auth != null
                  && (request.auth.uid in resource.data.users
                  || request.auth.token.email in ['abhishekbasu188@gmail.com']);
      allow create: if request.auth != null
                    && request.auth.uid in request.resource.data.users;
      allow delete: if request.auth != null
                    && request.auth.uid in resource.data.users;
      allow update: if false;
    }

    // ── Follows ──
    match /follows/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.followerId == request.auth.uid;
      allow delete: if request.auth != null
                    && resource.data.followerId == request.auth.uid;
      allow update: if request.auth != null
                    && request.auth.token.email in ['abhishekbasu188@gmail.com'];
    }

    // ── Private Conversations (messages.html) ──
    match /conversations/{convId} {
      allow read: if request.auth != null
                  && request.auth.uid in resource.data.members;
      allow create: if request.auth != null
                    && request.auth.uid in request.resource.data.members;
      allow update: if request.auth != null
                    && request.auth.uid in resource.data.members;
      allow delete: if false;

      match /messages/{msgId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
                      && request.resource.data.senderId == request.auth.uid
                      && request.resource.data.text.size() > 0
                      && request.resource.data.text.size() <= 2000;
        allow update: if request.auth != null
                      && resource.data.senderId == request.auth.uid;
        allow delete: if request.auth != null
                      && (resource.data.senderId == request.auth.uid
                      || request.auth.token.email in ['abhishekbasu188@gmail.com']);
      }
    }

    // ── PDF Likes ──
    match /pdfLikes/{likeId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid
                    && likeId == request.resource.data.pdfId + '_' + request.auth.uid;
      allow delete: if request.auth != null
                    && resource.data.userId == request.auth.uid;
      allow update: if false;
    }

    // ── PDF Subscriptions ──
    match /pdfSubscriptions/{subId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null
                    && resource.data.userId == request.auth.uid;
      allow update: if false;
    }

    // ── Comments on PDFs ──
    match /comments/{pdfId}/items/{commentId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.text.size() > 0
                    && request.resource.data.text.size() <= 500;
      allow delete: if request.auth != null
                    && (resource.data.userId == request.auth.uid
                    || request.auth.token.email in ['abhishekbasu188@gmail.com']);
      allow update: if false;
    }

    // ── Organizer Views ──
    match /organizerViews/{docId} {
      allow read: if request.auth != null
                  && request.auth.token.email in ['abhishekbasu188@gmail.com'];
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // ── Profile Views ──
    match /profileViews/{docId} {
      allow read: if request.auth != null
                  && resource.data.profileOwnerUid == request.auth.uid;
      allow create: if request.auth != null
                    && request.resource.data.viewerUid == request.auth.uid
                    && request.resource.data.viewerUid != request.resource.data.profileOwnerUid;
      allow update, delete: if false;
    }

    // ── Codespace Access Control ──
    match /codespaceAccess/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.token.email in ['abhishekbasu188@gmail.com'];
    }

    // ── Codespace Files ──
    match /codespaceFiles/{fileId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && canEditCodespace();
      allow update: if request.auth != null && canEditCodespace();
      allow delete: if request.auth != null
                    && request.auth.token.email in ['abhishekbasu188@gmail.com'];
    }

    // ── Codespace Presence ──
    match /codespacePresence/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == uid;
    }

    // ── Codespace Activity Log ──
    match /codespaceActivity/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // ── Purchases ──
    match /purchases/{docId} {
      allow read: if request.auth != null
                  && resource.data.userId == request.auth.uid;
      allow create, update: if request.auth != null
                  && request.auth.token.email in ['abhishekbasu188@gmail.com'];
      allow delete: if false;
    }

    // ── Pending Payments ──
    match /pendingPayments/{docId} {
      allow read: if request.auth != null
                  && (resource.data.userId == request.auth.uid
                  || request.auth.token.email in ['abhishekbasu188@gmail.com']);
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.utr.size() > 0
                    && request.resource.data.utr.size() <= 50;
      allow update: if request.auth != null
                    && request.auth.token.email in ['abhishekbasu188@gmail.com'];
      allow delete: if request.auth != null
                    && request.auth.token.email in ['abhishekbasu188@gmail.com'];
    }

    // ── Important Questions ──
    match /importantQuestions/{docId} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.token.email in ['abhishekbasu188@gmail.com'];
    }

    // ── Email Notifications log ──
    match /notificationLog/{docId} {
      allow read, write: if request.auth != null
                         && request.auth.token.email in ['abhishekbasu188@gmail.com'];
    }

    // ── User profiles ──
    match /userProfiles/{uid} {
      allow read: if true;
      allow write: if request.auth != null
                   && (request.auth.uid == uid
                   || request.auth.token.email in ['abhishekbasu188@gmail.com']);
    }

    // ── Status updates ──
    match /statuses/{uid} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.data.text.size() > 0
                   && request.resource.data.text.size() <= 150;
      allow delete: if request.auth != null
                   && request.auth.uid == uid;
    }

    // ── Video Sessions ──
    match /videoSessions/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.createdBy == request.auth.token.email;
      allow update, delete: if false;
    }

    // ── Download Requests (codespace 2-FA download flow) ──
    // Field name is `userId` (not `uid`) — rules must match the JS.
    // Users need read access on their own doc so the onSnapshot listener
    // (watching for admin approval) works without being blocked.
    match /downloadRequests/{docId} {
      // Signed-in user can create their own request
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.status == 'pending';

      // User can read their own request (needed for real-time approval watch)
      // Admin can read all
      allow read: if request.auth != null
                  && (resource.data.userId == request.auth.uid
                  || request.auth.token.email in ['abhishekbasu188@gmail.com']);

      // ── UPDATE ──
      // Admin can update any field (approve / reject / mark completed).
      // A regular user may:
      //   (a) move their own *pending* request to 'cancelled', or
      //   (b) once their request is 'approved', flip it to 'completed'
      //       and/or stamp 'downloadedAt' — this is what lets the client
      //       log the moment the file was actually downloaded, so the
      //       admin panel can show an accurate download timestamp.
      // No other field or transition is allowed through.
      allow update: if request.auth != null
                    && (
                      request.auth.token.email in ['abhishekbasu188@gmail.com']
                      ||
                      (resource.data.userId == request.auth.uid
                       && resource.data.status == 'pending'
                       && request.resource.data.status == 'cancelled'
                       && request.resource.data.diff(resource.data).affectedKeys()
                            .hasOnly(['status', 'cancelledAt']))
                      ||
                      (resource.data.userId == request.auth.uid
                       && resource.data.status in ['approved', 'completed']
                       && request.resource.data.status in ['approved', 'completed']
                       && request.resource.data.diff(resource.data).affectedKeys()
                            .hasOnly(['status', 'completedAt', 'downloadedAt']))
                    );

      allow delete: if false;
    }

    // ── Download Access grants (admin-managed) ──
    match /downloadAccess/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.token.email in ['abhishekbasu188@gmail.com'];
    }

    // ── Waiting Room (host approval before joining video call) ──
    match /waitingRoom/{docId} {
      allow read: if request.auth != null
                  && (request.auth.token.email in ['abhishekbasu188@gmail.com']
                  || resource.data.uid == request.auth.uid);
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid;
      allow update: if request.auth != null
                    && (request.auth.token.email in ['abhishekbasu188@gmail.com']
                    || resource.data.uid == request.auth.uid);
      allow delete: if request.auth != null
                    && (request.auth.token.email in ['abhishekbasu188@gmail.com']
                    || resource.data.uid == request.auth.uid);
    }

    // ── Announcements (e.g. "jobs & exams alerts" coming-soon banner) ──
    match /announcements/{id} {
      allow read: if true;

      // Allow seeding the doc once with the exact empty shape the app expects.
      // Prevents random/malformed announcement docs from being created.
      allow create: if request.auth != null
                    && request.resource.data.keys().hasOnly(['likes','likedBy','notifiedBy'])
                    && request.resource.data.likes == 0
                    && request.resource.data.likedBy == []
                    && request.resource.data.notifiedBy == [];

      allow update: if request.auth != null && (
        // Like / unlike: caller may only add or remove their OWN uid,
        // one at a time, and the counter must move in lockstep.
        (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes','likedBy'])
          && (
            ( !(request.auth.uid in resource.data.likedBy)
              && request.auth.uid in request.resource.data.likedBy
              && request.resource.data.likedBy.size() == resource.data.likedBy.size() + 1
              && request.resource.data.likes == resource.data.likes + 1 )
            ||
            ( request.auth.uid in resource.data.likedBy
              && !(request.auth.uid in request.resource.data.likedBy)
              && request.resource.data.likedBy.size() == resource.data.likedBy.size() - 1
              && request.resource.data.likes == resource.data.likes - 1 )
          )
        )
        ||
        // Notify me: caller may only add their own uid, once.
        (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['notifiedBy'])
          && !(request.auth.uid in resource.data.notifiedBy)
          && request.auth.uid in request.resource.data.notifiedBy
          && request.resource.data.notifiedBy.size() == resource.data.notifiedBy.size() + 1
        )
      );

      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 300;
        allow delete: if request.auth != null
          && (resource.data.uid == request.auth.uid || request.auth.token.email in ['abhishekbasu188@gmail.com']);
        allow update: if false;
      }
    }

    // ── Opportunities (auto-pulled job/exam/scholarship alerts) ──
    // Written only by the GitHub Actions fetch script via the Admin SDK
    // (which bypasses these rules entirely) — so clients get zero write access.
    match /opportunities/{id} {
      allow read: if true;
      allow write: if false;
    }

    // ── Per-user "last seen" marker for the opportunities bell badge ──
    match /opportunitySeen/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

  }
}
